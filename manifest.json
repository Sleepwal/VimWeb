{
  "manifest_version": 3,
  "name": "Vim Web",
  "version": "0.2",
  "description": "Make the web navigable by keyboard, Vim-style.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Vim Web Help"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["utils.js", "hint.js", "content.js"],
      "css": ["hint.css", "indicator.css"],
      "run_at": "document_idle"
    }
  ]
}
